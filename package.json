{
  "name": "notion-for-linux",
  "version": "1.0.0",
  "description": "Unofficial Notion desktop client for Linux",
  "productName": "Notion",
  "desktopName": "notion-for-linux",
  "main": "dist/main/index.js",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "bun run build && electron .",
    "dev": "bun run build && electron .",
    "dist": "bun run build && bunx electron-builder --linux",
    "dist:deb": "bun run build && bunx electron-builder --linux deb",
    "dist:rpm": "bun run build && bunx electron-builder --linux rpm",
    "dist:appimage": "bun run build && bunx electron-builder --linux AppImage",
    "dist:all": "bun run build && bunx electron-builder --linux deb rpm AppImage",
    "clean": "rm -rf dist release",
    "version:sync": "bun scripts/sync-version.ts",
    "version:tag": "bun scripts/tag-version.ts"
  },
  "build": {
    "appId": "com.tylerdinh.notion-for-linux",
    "productName": "Notion",
    "executableName": "notion-for-linux",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/index.js"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "assets/icon.png",
      "category": "Office",
      "executableName": "notion-for-linux",
      "syncDesktopName": true,
      "synopsis": "Unofficial Notion desktop client for Linux",
      "description": "A simple and efficient unofficial desktop client for Notion on Linux.",
      "desktop": {
        "entry": {
          "Name": "Notion",
          "Comment": "Unofficial Notion desktop client",
          "Categories": "Office;Network;",
          "StartupWMClass": "notion-for-linux",
          "Icon": "notion-for-linux"
        }
      },
      "artifactName": "${name}-${version}-${arch}.${ext}"
    },
    "deb": {
      "packageCategory": "office",
      "priority": "optional"
    },
    "rpm": {
      "packageCategory": "Office"
    }
  },
  "keywords": [
    "Electron",
    "Notion",
    "notion-for-linux",
    "Linux",
    "desktop"
  ],
  "author": {
    "name": "Tyler Dinh",
    "email": "vantaidinh04@hotmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/Tylerx404/Notion-for-Linux",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "electron-context-menu": "^4.1.2"
  }
}
